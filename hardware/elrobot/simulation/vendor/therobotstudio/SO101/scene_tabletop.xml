<mujoco model="scene_tabletop">
    <!-- SO-101 on a tabletop with a grab target and fixed cameras -->
    <include file="so101_new_calib.xml" />

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
        <rgba haze="0.15 0.25 0.35 1" />
        <global azimuth="160" elevation="-20" />
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
                 width="512" height="3072" />
        <texture type="2d" name="groundplane" builtin="checker" mark="edge"
                 rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
                 width="300" height="300" />
        <material name="groundplane" texture="groundplane" texuniform="true"
                  texrepeat="5 5" reflectance="0.2" />

        <!-- Table surface -->
        <texture type="2d" name="table_tex" builtin="flat" rgb1="0.6 0.5 0.4"
                 width="64" height="64" />
        <material name="table_mat" texture="table_tex" reflectance="0.1" />

        <!-- Cube target -->
        <material name="cube_red" rgba="0.9 0.2 0.2 1" />
    </asset>

    <worldbody>
        <light pos="0 0 1.5" dir="0 0 -1" directional="true" />
        <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"
              pos="0 0 -0.05" />

        <!-- Table: flat surface where the robot sits -->
        <body name="table" pos="0.15 0 -0.005">
            <geom name="tabletop" type="box" size="0.25 0.20 0.005"
                  material="table_mat" mass="10" />
        </body>

        <!-- Cube: graspable target object -->
        <body name="cube" pos="0.20 0.0 0.025">
            <joint name="cube_joint" type="free" />
            <geom name="cube_geom" type="box" size="0.02 0.02 0.02"
                  material="cube_red" mass="0.05"
                  friction="1.0 0.005 0.0001" />
        </body>

        <!-- Fixed cameras matching typical SO-101 setups -->
        <camera name="top" pos="0.15 0.0 0.50" xyaxes="1 0 0 0 1 0"
                fovy="50" />
        <camera name="wrist.top" pos="-0.05 -0.30 0.35" xyaxes="1 0 0 0 0.5 1"
                fovy="55" />
    </worldbody>
</mujoco>
