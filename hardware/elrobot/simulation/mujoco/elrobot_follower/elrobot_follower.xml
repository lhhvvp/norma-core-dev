<mujoco model="elrobot_follower">
  <!-- Hand-written MJCF for MVP-2 Phase 2.
       Physics parameters inherited from mujoco_menagerie/trs_so_arm100
       (armature=0.1, frictionloss=0.1, kp=50, dampratio=1); forcerange
       (-2.94 2.94) is from the URDF effort limit (ST3215 rated torque),
       not Menagerie's simulated +-3.5.

       Kinematics (body tree, joint axes, ranges, parent-relative offsets)
       are sourced from elrobot_follower.urdf. The 8 "Rigid N" fixed URDF
       joints are collapsed by merging each ST3215_N_v1_1 motor link's
       mass and inertia into the parent body (see <inertial> entries).

       Collision geometry uses primitive boxes/cylinders only — no mesh
       collision — per MVP-2 spec 7.3 to avoid MVP-1 self-collision issues.

       The gripper mimic (rev_motor_08_1, rev_motor_08_2 prismatic joints
       coupled to rev_motor_08 via <tendon><fixed> + <equality><tendon>
       with multipliers +/-0.0115) is preserved verbatim from the MVP-1
       MJCF — this is the P0 invariant per MVP-2 plan Chunk 5 Task 5.2. -->

  <compiler angle="radian" meshdir="../../assets" autolimits="true"/>

  <option cone="elliptic" impratio="10"/>

  <default>
    <default class="elrobot">
      <joint frictionloss="0.1" armature="0.1"/>
      <position kp="50" dampratio="1" forcerange="-2.94 2.94"/>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" density="0" group="2" rgba="0.7 0.7 0.7 1"/>
        <default class="motor_visual">
          <geom rgba="0.1 0.1 0.1 1"/>
        </default>
      </default>
      <default class="collision">
        <geom group="3" rgba="0.5 0.6 0.8 0.3"/>
      </default>
    </default>
  </default>

  <asset>
    <mesh name="base_link" file="base_link.stl" scale="0.001 0.001 0.001"/>
    <mesh name="ST3215_1_v1_1" file="ST3215_1_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Joint_01_1" file="Joint_01_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="ST3215_2_v1_1" file="ST3215_2_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Joint_02_1" file="Joint_02_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="ST3215_3_v1_1" file="ST3215_3_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Joint_03_v1_1" file="Joint_03_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="ST3215_4_v1_1" file="ST3215_4_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Joint_04_v1_1" file="Joint_04_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="ST3215_5_v1_1" file="ST3215_5_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Joint_05_v1_1" file="Joint_05_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="ST3215_6_v1_1" file="ST3215_6_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Joint_06_v1_1" file="Joint_06_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="ST3215_7_v1_1" file="ST3215_7_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Gripper_Base_v1_1" file="Gripper_Base_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="ST3215_8_v1_1" file="ST3215_8_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Gripper_Gear_v1_1" file="Gripper_Gear_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Gripper_Jaw_02_v1_1" file="Gripper_Jaw_02_v1_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="Gripper_Jaw_01_v1_1" file="Gripper_Jaw_01_v1_1.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <worldbody>
    <body name="base_link" childclass="elrobot">
      <!-- base_link mass (0.03944) + ST3215_1 motor (0.055) merged via Rigid 1 -->
      <inertial pos="0 0.013084 0.019551" mass="0.09444"
                diaginertia="4.4e-05 6.3e-05 5.8e-05"/>
      <geom mesh="base_link" class="visual"/>
      <geom mesh="ST3215_1_v1_1" class="motor_visual" pos="0 0.007585 0.0315"/>
      <geom name="base_col" type="box" size="0.04 0.04 0.018" pos="0 0.013 0.018" class="collision"/>

      <body name="Joint_01_1" pos="0 0.042489 0.049005">
        <!-- Joint_01_1 (0.05706) + ST3215_2 (0.055) merged via Rigid 3 -->
        <inertial pos="0 0.010535 -0.002903" mass="0.11206"
                  diaginertia="2.7e-05 2.8e-05 1.4e-05"/>
        <joint name="rev_motor_01" pos="0 0 0" axis="0 -0.008727 0.999962"
               range="-1.5509 1.5509"/>
        <geom mesh="Joint_01_1" class="visual" pos="0 -0.042489 -0.049005"/>
        <geom mesh="ST3215_2_v1_1" class="motor_visual" pos="0 -0.042489 -0.049005"/>
        <geom name="j01_col" type="box" size="0.022 0.022 0.018" pos="0 0.008 0.005" class="collision"/>

        <body name="Joint_02_1" pos="-0.019668 -0.000366 0.041933">
          <!-- Joint_02_1 (0.05084) + ST3215_3 (0.055) merged via Rigid 7 -->
          <inertial pos="0.020187 -0.000361 0.040489" mass="0.10584"
                    diaginertia="3.1e-05 4.2e-05 2.1e-05"/>
          <joint name="rev_motor_02" pos="0 0 0" axis="-0.999962 -7.6e-05 0.008726"
                 range="-1.6122 1.6122"/>
          <geom mesh="Joint_02_1" class="visual" pos="0.019668 -0.042123 -0.090938"/>
          <geom mesh="ST3215_3_v1_1" class="motor_visual" pos="0.019668 -0.042123 -0.090938"/>
          <geom name="j02_col" type="box" size="0.018 0.018 0.032" pos="0.018 0 0.036" class="collision"/>

          <body name="Joint_03_v1_1" pos="-0.000122 -0.000796 0.091235">
            <!-- Joint_03 (0.03822) + ST3215_4 (0.055) merged via Rigid 9 -->
            <inertial pos="0.021383 0.002597 0.028573" mass="0.09322"
                      diaginertia="1.8e-05 2.2e-05 2.3e-05"/>
            <joint name="rev_motor_03" pos="0 0 0" axis="-0.999848 -0.000152 0.017452"
                   range="-1.7610 1.7610"/>
            <geom mesh="Joint_03_v1_1" class="visual" pos="0.01979 -0.041327 -0.182173"/>
            <geom mesh="ST3215_4_v1_1" class="motor_visual" pos="0.01979 -0.041327 -0.182173"/>
            <geom name="j03_col" type="box" size="0.018 0.018 0.028" pos="0.019 0.002 0.028" class="collision"/>

            <body name="Joint_04_v1_1" pos="0.000973 0.037162 0.037065">
              <!-- Joint_04 (0.05152) + ST3215_5 (0.055) merged via Rigid 11 -->
              <inertial pos="0.020415 0.046348 0.000473" mass="0.10652"
                        diaginertia="4.5e-05 2.8e-05 5.1e-05"/>
              <joint name="rev_motor_04" pos="0 0 0" axis="-0.99981 0.008574 0.017527"
                     range="-1.7533 1.7533"/>
              <geom mesh="Joint_04_v1_1" class="visual" pos="0.018817 -0.078489 -0.219238"/>
              <geom mesh="ST3215_5_v1_1" class="motor_visual" pos="0.018817 -0.078489 -0.219238"/>
              <geom name="j04_col" type="box" size="0.018 0.044 0.018" pos="0.018 0.044 0" class="collision"/>

              <body name="Joint_05_v1_1" pos="0.020714 0.082863 1.6e-05">
                <!-- Joint_05 (0.01756) + ST3215_6 (0.055) merged via Rigid 13 -->
                <inertial pos="-0.001451 0.014886 0.000239" mass="0.07256"
                          diaginertia="1.0e-05 9e-06 1.3e-05"/>
                <joint name="rev_motor_05" pos="0 0 0" axis="-0.008573 -0.999963 0.000151"
                       range="-3.1907 2.6998"/>
                <geom mesh="Joint_05_v1_1" class="visual" pos="-0.001897 -0.161352 -0.219254"/>
                <geom mesh="ST3215_6_v1_1" class="motor_visual" pos="-0.001897 -0.161352 -0.219254"/>
                <geom name="j05_col" type="box" size="0.018 0.014 0.018" pos="0 0.013 0" class="collision"/>

                <body name="Joint_06_v1_1" pos="-0.019923 0.042907 0.00035">
                  <!-- Joint_06 (0.03882) + ST3215_7 (0.055) merged via Rigid 15 -->
                  <inertial pos="0.020434 0.031977 0.000356" mass="0.09382"
                            diaginertia="2.4e-05 2.3e-05 2.6e-05"/>
                  <joint name="rev_motor_06" pos="0 0 0" axis="-0.999697 0.0173 0.017525"
                         range="-1.3775 1.7641"/>
                  <geom mesh="Joint_06_v1_1" class="visual" pos="0.018026 -0.204259 -0.219604"/>
                  <geom mesh="ST3215_7_v1_1" class="motor_visual" pos="0.018026 -0.204259 -0.219604"/>
                  <geom name="j06_col" type="box" size="0.018 0.030 0.018" pos="0.018 0.030 0" class="collision"/>

                  <body name="Gripper_Base_v1_1" pos="0.020951 0.055307 -0.000712">
                    <!-- Gripper_Base (0.06244) + ST3215_8 (0.055) merged via Rigid 17 -->
                    <inertial pos="0.000561 0.031920 -0.000595" mass="0.11744"
                              diaginertia="3.0e-05 3.6e-05 3.5e-05"/>
                    <joint name="rev_motor_07" pos="0 0 0" axis="-0.017144 -0.999812 0.009029"
                           range="-3.0710 2.7796"/>
                    <geom mesh="Gripper_Base_v1_1" class="visual" pos="-0.002925 -0.259566 -0.218892"/>
                    <geom mesh="ST3215_8_v1_1" class="motor_visual" pos="-0.002925 -0.259566 -0.218892"/>
                    <geom name="gbase_col" type="box" size="0.020 0.028 0.018" pos="0 0.030 0" class="collision"/>

                    <body name="Gripper_Gear_v1_1" pos="0.000776 0.045242 -0.000409">
                      <!-- Near-zero URDF inertia; diaginertia floor per comparison-table Risk note. -->
                      <inertial pos="6.4e-05 0.003756 -3.4e-05" mass="0.0039"
                                diaginertia="1e-06 1e-06 1e-06"/>
                      <joint name="rev_motor_08" pos="0 0 0" axis="0.017144 0.999812 -0.009029"
                             range="0 2.2028"/>
                      <geom mesh="Gripper_Gear_v1_1" class="motor_visual" pos="-0.003701 -0.304808 -0.218483"/>
                      <geom name="ggear_col" type="cylinder" size="0.008 0.004" pos="0 0.004 0"
                            euler="1.5708 0 0" class="collision"/>
                    </body>

                    <body name="Gripper_Jaw_02_v1_1" pos="0.311734 -0.199648 0.032849">
                      <!-- URDF COM origin is in world coordinates (clearly broken); reset to body origin.
                           Mass/inertia values from URDF. -->
                      <inertial pos="0 0 0" mass="0.0125"
                                diaginertia="5e-06 4e-06 3e-06"/>
                      <joint name="rev_motor_08_1" pos="0 0 0" axis="-0.999697 0.0173 0.017525"
                             type="slide" range="-0.0255 0"/>
                      <geom mesh="Gripper_Jaw_02_v1_1" class="visual" pos="-0.314659 -0.059918 -0.251741"/>
                      <geom name="jaw02_col" type="box" size="0.002 0.015 0.006" pos="0 -0.022 0" class="collision"/>
                    </body>

                    <body name="Gripper_Jaw_01_v1_1" pos="0.308573 -0.243367 -0.049391">
                      <!-- URDF COM origin is in world coordinates (clearly broken); reset to body origin.
                           Mass/inertia values from URDF. -->
                      <inertial pos="0 0 0" mass="0.0125"
                                diaginertia="5e-06 4e-06 3e-06"/>
                      <joint name="rev_motor_08_2" pos="0 0 0" axis="-0.999697 0.0173 0.017525"
                             type="slide" range="0 0.0255"/>
                      <geom mesh="Gripper_Jaw_01_v1_1" class="visual" pos="-0.311498 -0.016199 -0.171401"/>
                      <geom name="jaw01_col" type="box" size="0.002 0.015 0.006" pos="0 -0.022 0" class="collision"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Gripper mimic tendon coupling — preserved from MVP-1 MJCF, P0 invariant. -->
  <tendon>
    <fixed name="mimic_rev_motor_08_1">
      <joint joint="rev_motor_08_1" coef="1"/>
      <joint joint="rev_motor_08" coef="0.0115"/>
    </fixed>
    <fixed name="mimic_rev_motor_08_2">
      <joint joint="rev_motor_08_2" coef="1"/>
      <joint joint="rev_motor_08" coef="-0.0115"/>
    </fixed>
  </tendon>

  <equality>
    <tendon tendon1="mimic_rev_motor_08_1" solref="0.002 1" solimp="0.99 0.999 0.0001 0.5 2"/>
    <tendon tendon1="mimic_rev_motor_08_2" solref="0.002 1" solimp="0.99 0.999 0.0001 0.5 2"/>
  </equality>

  <contact>
    <!-- Parent-child pairs that cannot physically self-collide in rigid
         articulation but whose primitive collision boxes slightly overlap
         or touch at rest. Without these excludes, M1 (and possibly other
         motors) would stall on motion-dependent self-contact. Rest-pose
         ncon=0 doesn't catch these; only a full joint-range sweep does.
         See Task 5.2 code-review Critical C1 for the analysis. -->
    <exclude body1="base_link" body2="Joint_01_1"/>
    <!-- Additional motion-dependent pairs found by full-range sweep (2026-04-12).
         M3 +80% sweeps Joint_04 and Joint_05 near Joint_01's collision box;
         M4 +80% sweeps Joint_06 near Joint_01's collision box. These are
         kinematically valid configurations (the arm folds back on itself) but
         produce self-contact stall in the MuJoCo PD controller. -->
    <exclude body1="Joint_01_1" body2="Joint_04_v1_1"/>
    <exclude body1="Joint_01_1" body2="Joint_05_v1_1"/>
    <exclude body1="Joint_01_1" body2="Joint_06_v1_1"/>
    <!-- Round-2 sweep residuals (2026-04-12): M3/M4 +80% also folds
         Joint_02 near Joint_04/Joint_05, and M4 folds Gripper_Base near
         Joint_01. All physically consistent fold-back configurations. -->
    <exclude body1="Joint_02_1" body2="Joint_04_v1_1"/>
    <exclude body1="Joint_02_1" body2="Joint_05_v1_1"/>
    <exclude body1="Joint_01_1" body2="Gripper_Base_v1_1"/>
    <!-- Round-3 sweep residuals (2026-04-12): M3/M4 +80% folds distal links
         (Joint_05, Joint_06, Gripper_Base) back to the base_link box. -->
    <exclude body1="base_link" body2="Joint_05_v1_1"/>
    <exclude body1="base_link" body2="Joint_06_v1_1"/>
    <exclude body1="base_link" body2="Gripper_Base_v1_1"/>
    <!-- Round-4 sweep residual (2026-04-12): M4 +80% folds Joint_06 near
         Joint_02's box as the arm folds back. -->
    <exclude body1="Joint_02_1" body2="Joint_06_v1_1"/>
  </contact>

  <actuator>
    <!-- Floor 4 overshoot forecast (code-review I1, 2026-04-12):
         kp=50, dampratio=1, forcerange=±2.94 produces saturated-PD bang-bang
         on large steps. Expected overshoot per code-review empirical prediction:
           M1:  8.6% PASS  M2: 26.3% FAIL  M3: 25.2% FAIL  M4: 18.8% FAIL
           M5: 23.5% FAIL  M6: 13.2% PASS  M7: 24.4% FAIL  M8: 18.1% FAIL
         Chunk 6 Floor 4 test will surface these. The plan + comparison-table
         amendment explicitly permit bumping forcerange to ±3.5 with CHANGELOG
         note, OR raising dampratio to ~1.3–1.5 to absorb saturation overshoot.
         Do NOT raise kp — it worsens saturation. -->
    <position class="elrobot" name="act_motor_01" joint="rev_motor_01"
              ctrlrange="-1.5509 1.5509"/>
    <position class="elrobot" name="act_motor_02" joint="rev_motor_02"
              ctrlrange="-1.6122 1.6122"/>
    <position class="elrobot" name="act_motor_03" joint="rev_motor_03"
              ctrlrange="-1.7610 1.7610"/>
    <position class="elrobot" name="act_motor_04" joint="rev_motor_04"
              ctrlrange="-1.7533 1.7533"/>
    <position class="elrobot" name="act_motor_05" joint="rev_motor_05"
              ctrlrange="-3.1907 2.6998"/>
    <position class="elrobot" name="act_motor_06" joint="rev_motor_06"
              ctrlrange="-1.3775 1.7641"/>
    <position class="elrobot" name="act_motor_07" joint="rev_motor_07"
              ctrlrange="-3.0710 2.7796"/>
    <position class="elrobot" name="act_motor_08" joint="rev_motor_08"
              ctrlrange="0 2.2028"/>
  </actuator>
</mujoco>
